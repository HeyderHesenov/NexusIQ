# Frontend env — kopyala: cp .env.local.example .env.local

# Brauzer sorğuları eyni-origin `/backend` proksisi üzərindən gedir (cookie/CSRF).
NEXT_PUBLIC_API_BASE=/backend

# Server-only: Next `/backend/*` rewrite-ının hədəfi (BUILD zamanı oxunur).
BACKEND_INTERNAL_URL=http://127.0.0.1:8001/api/v1

# Google girişi (real Gmail üçün). Boş qalsa Google düyməsi deaktiv olur.
# Google Cloud Console → Credentials → OAuth Client ID (Web) yarat,
# "Authorized JavaScript origins"-ə http://localhost:3000 əlavə et.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
