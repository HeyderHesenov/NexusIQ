# ============================================================
#  NexusIQ backend — environment template
#  Kopyala: cp .env.example .env  və dəyərləri doldur.
# ============================================================

# ---- App ----
APP_NAME=NexusIQ
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Database (lokal Postgres) ----
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexusiq

# ---- AI (LLM provayderi — birincili / ikincili model) ----
# Açar + model adını öz LLM provayderindən doldur.
LLM_PRIMARY_KEY=
LLM_PRIMARY_MODEL=
LLM_SECONDARY_KEY=
LLM_SECONDARY_MODEL=
LLM_EMBED_MODEL=

# ---- AI Advisor (2 AI debate) ----
ADVISOR_MAX_DEBATE_ROUNDS=3
ADVISOR_TRANSLATE_TARGET=az

# ---- Ingestion ----
INGEST_INTERVAL_MINUTES=60
INGEST_USER_AGENT=NexusIQ/1.0 (+local)

# ---- Analytics ----
CORRELATION_DEFAULT_WINDOW_DAYS=90
