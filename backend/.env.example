# ============================================================
#  NexusIQ backend — environment template
#  Kopyala: cp .env.example .env  və dəyərləri doldur.
#  Boş buraxılan sahələr üçün config.py-dəki default işləyir.
#  Sirlər (LLM açarları, VAPID) HEÇ VAXT commit olunmur — .env gitignored-dur.
# ============================================================

# ---- App ----
APP_NAME=NexusIQ
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Təhlükəsizlik ----
# X-Forwarded-For başlığına YALNIZ etibarlı reverse-proxy arxasında inan.
# Lokal tək-proses işləmədə proksi yoxdur → False (spoofing bağlıdır).
TRUSTED_PROXY=false
# Vergüllə ayrılmış Host allowlist (Host inyeksiyasına qarşı). "*" = yoxlama yoxdur
# (lokal dev defaultu); publik deploy-da real domen yaz.
TRUSTED_HOSTS=*
# HSTS YALNIZ HTTPS arxasında məna daşıyır. Lokal HTTP-də açma.
HSTS_ENABLED=false

# ---- Database (lokal Postgres) ----
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# QEYD: pg :5433-də (5432-ni yad PostgreSQL tuta bilər — bax scripts/pg_ensure.sh).
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5433/nexusiq
# Opsional: migrasiyaları fərqli URL-ə qarşı işlətmək üçün override.
# Verilməsə DATABASE_URL işlədilir (bax alembic/env.py).
# ALEMBIC_DB_URL=

# ---- AI (LLM provayderi — birincili / ikincili model) ----
# Açar + model adını öz LLM provayderindən doldur. Boşdursa AI funksiyaları
# zərif söndürülür (qeyri-AI endpoint-lər işləməyə davam edir).
LLM_PRIMARY_KEY=
LLM_PRIMARY_MODEL=
LLM_SECONDARY_KEY=
LLM_SECONDARY_MODEL=
LLM_EMBED_MODEL=

# ---- Ingestion ----
INGEST_INTERVAL_MINUTES=60

# ---- Scheduler ----
SCHEDULER_ENABLED=true
# Saatlıq ingestion + scoring PULSUZdur. AI tərcümə XƏRC tələb edir → default off.
SCHEDULER_AI_PROCESS=false
SCHEDULER_AI_BATCH=8

# ---- Embeddings (Tarixi Analoq motoru) ----
# Xəbər embedding-i (ucuz model). AI açarı lazımdır; söndürülsə motor boş
# nəticə qaytarır (UI sınmır).
EMBED_ENABLED=true
EMBED_BATCH=32

# ---- Proqnoz doğruluq motoru ----
# Forecast linklərini real qiymət hərəkəti ilə qiymətləndirir (PULSUZ, LLM yox).
SCORER_ENABLED=true

# ---- Pulsuz maşın tərcüməsi (Google free endpoint) ----
# Xəbərləri 4 dilə SADİQ tərcümə edir (AI kimi yenidən yazmır). Xərcsiz → aktiv.
FREE_TRANSLATE_ENABLED=true
# Saatlıq backfill ölçüsü. Çox yüksək → Google rate-limit → ingiliscə "zəhərlənmə".
FREE_TRANSLATE_BATCH=30

# ---- AI xülasə (təsvirsiz xəbərlər üçün, AI — XƏRC) ----
AI_SUMMARY_ENABLED=true
AI_SUMMARY_BATCH=8
# Avtomatik dövr yalnız son N günün təsvirsiz xəbərlərini emal edir (xərc nəzarəti).
AI_SUMMARY_MAX_AGE_DAYS=21

# ---- Web Push (VAPID) ----
# Cütü yarat:  python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); ..."
# Boşdursa push söndürülür. Bunlar SİRDİR — commit etmə.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@nexusiq.local
