# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4

[*.{js,jsx,ts,tsx,mjs,cjs,json,css,scss,yml,yaml,html}]
indent_size = 2

[*.sh]
indent_size = 2

# Markdown: trailing whitespace can be a hard line break
[*.md]
trim_trailing_whitespace = false
